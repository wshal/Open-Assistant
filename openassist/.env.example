# ━━━ TIER 1: Ultra Fast & Free ━━━

# Groq — 1300 tok/s, 30 RPM free
# https://console.groq.com/keys  
GROQ_API_KEY=

# Cerebras — 2100 tok/s (world's fastest), 30 RPM free
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# SambaNova — Llama 405B & DeepSeek R1 FREE
# https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=

# ━━━ TIER 2: High Quality & Free ━━━

# Google Gemini — 1M tokens/day free, best quality
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Together AI — $5 free credit, fast open models
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# OpenRouter — Free models (Llama, Qwen, DeepSeek)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral — Codestral free for coding
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# Cohere — 1000 req/month free, best for RAG
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Hyperbolic — $10 free credit, DeepSeek V3/R1
# https://app.hyperbolic.xyz/
HYPERBOLIC_API_KEY=

# ━━━ TIER 3: Paid (Optional) ━━━
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ━━━ Local (No key needed) ━━━
OLLAMA_ENDPOINT=http://localhost:11434