# =============================================================================
# OpenAssist — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
lib/
lib64/
*.manifest

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env.bak
openassist/venv/

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
*.env
!.env.example

# -----------------------------------------------------------------------------
# PyInstaller / Build Artifacts
# -----------------------------------------------------------------------------
*.spec
!build.spec
dist/
build/
*.exe
*.dmg
*.pkg
*.msi
openassist/dist/
openassist/build/

# -----------------------------------------------------------------------------
# Data, Cache & Runtime Files
# -----------------------------------------------------------------------------
openassist/data/
openassist/knowledge/
*.db
*.sqlite
*.sqlite3
*.cache
*.log
*.tmp
*.temp
logs/
cache/
tmp/

# -----------------------------------------------------------------------------
# Audio / Media Captures
# -----------------------------------------------------------------------------
*.wav
*.mp3
*.mp4
*.ogg
*.flac
*.aac
*.webm
*.mkv
captures/

# -----------------------------------------------------------------------------
# AI / Model Artefacts
# -----------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.bin
*.safetensors
models/
checkpoints/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
desktop.ini
ehthumbs.db
$RECYCLE.BIN/
nul

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# MyPy / Type Checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Packaging / Lock Files (keep requirements.txt, ignore generated locks)
# -----------------------------------------------------------------------------
Pipfile.lock
poetry.lock
